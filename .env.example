# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sfhacks

# ──────────────────────────────────────────────
# JWT / Auth
# ──────────────────────────────────────────────
JWT_SECRET=change_me_before_production

# ──────────────────────────────────────────────
# Client (Vite exposes variables prefixed with VITE_)
# ──────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
